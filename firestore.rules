rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin: email fijo o role=='admin' en users/{uid}
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'luis.leon.cardenas@gmail.com'
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isPrivateEvent(data) {
      return data.get('isPrivate', false) == true;
    }

    function isEventMember(data) {
      return request.auth != null
        && data.get('registeredUserIds', []).hasAny([request.auth.uid]);
    }

    // Usuarios: cada uno lee/edita su propio perfil, autenticados pueden listar, admin gestiona todo
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Eventos
    match /events/{eventId} {
      // Admin: acceso total
      allow read, write: if isAdmin();

      // Lectura: eventos activos públicos o privados a los que el usuario pertenece
      allow read: if resource.data.status == 'active'
        && (!isPrivateEvent(resource.data) || isEventMember(resource.data));

      // Auto-inscripción: sólo en eventos PÚBLICOS. Incrementa cupo en 1 y añade su propio uid.
      allow update: if request.auth != null
        && !isPrivateEvent(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['currentSlots', 'registeredUserIds', 'updatedAt'])
        && request.resource.data.currentSlots == resource.data.currentSlots + 1
        && request.resource.data.registeredUserIds
             .hasAll(resource.data.get('registeredUserIds', []))
        && request.resource.data.registeredUserIds.size()
             == resource.data.get('registeredUserIds', []).size() + 1
        && request.auth.uid in request.resource.data.registeredUserIds;

      // Auto-cancelación: espejo del anterior. Decrementa cupo en 1 y remueve su propio uid.
      allow update: if request.auth != null
        && !isPrivateEvent(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['currentSlots', 'registeredUserIds', 'updatedAt'])
        && request.resource.data.currentSlots == resource.data.currentSlots - 1
        && resource.data.registeredUserIds.hasAny([request.auth.uid])
        && !(request.auth.uid in request.resource.data.registeredUserIds)
        && request.resource.data.registeredUserIds.size()
             == resource.data.registeredUserIds.size() - 1;
    }

    // Inscripciones
    match /registrations/{regId} {
      // Admin: acceso total
      allow read, write: if isAdmin();

      // Dueño: lee su propia inscripción
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Usuario crea su propia inscripción sólo en eventos públicos (los privados los crea el admin)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.get('registeredBy', 'self') == 'self'
        && get(/databases/$(database)/documents/events/$(request.resource.data.eventId))
             .data.get('isPrivate', false) == false;

      // Sólo puede borrar las inscripciones que el mismo usuario creó (no las añadidas por admin)
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && resource.data.get('registeredBy', 'self') == 'self';
    }

    // Experiencias: todos leen, sólo admin escribe
    match /experiences/{expId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
