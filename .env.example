# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudinary (subida de imágenes — alternativa gratis a Firebase Storage)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# Admin Configuration
# Email del primer administrador (el primer usuario con este email será admin automáticamente)
VITE_ADMIN_EMAIL=admin@tuacademia.com

# App Configuration
VITE_APP_NAME=Academia de Fútbol
VITE_APP_SHORT_NAME=FutbolAcademy

# Firebase Cloud Messaging (opcional para notificaciones push)
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here
